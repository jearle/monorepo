{
  "name": "@jearle/app-__skeleton",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "__skeleton": "./src/main.ts"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*/index.ts",
      "types": "./src/*/index.ts"
    }
  },
  "scripts": {
    "format": "bun run repo package format",
    "start": "bun src/main.ts",
    "cli": "bun src/main.ts",
    "compile": "bun run repo package compile",
    "lint": "bun run repo package lint",
    "test": "bun run repo package test",
    "verify": "bun run repo package verify"
  },
  "dependencies": {
    "@jearle/util-env": "workspace:*",
    "@jearle/util-logger": "workspace:*"
  },
  "peerDependencies": {
    "@bunli/core": "^0",
    "zod": "^4"
  },
  "devDependencies": {
    "@jearle/config-oxlint": "workspace:*",
    "@jearle/config-tsconfig": "workspace:*"
  }
}
