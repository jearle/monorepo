    "test": "bun run repo package test",
    "verify": "bun run repo package verify"
  },
  "dependencies": {
    "@jearle/util-math": "workspace:*",
    "convert": "7.0.0"
  },
  "peerDependencies": {
    "lodash.camelcase": "^4",
    "lodash.mapkeys": "^4",
    "lodash.snakecase": "^4"
  },
  "devDependencies": {
    "@jearle/config-oxlint": "workspace:*",
    "@jearle/config-tsconfig": "workspace:*"
  }
}
