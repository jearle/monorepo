{
  "name": "@jearle/util-convert",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*/index.ts",
      "types": "./src/*/index.ts"
    }
  },
  "scripts": {
    "format": "bun run repo package format",
    "compile": "bun run repo package compile",
