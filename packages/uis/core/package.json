{
  "name": "@jearle/ui-core",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./styles/*": {
      "default": "./src/styles/*.module.css"
    },
    "./*": {
      "import": "./src/*/index.ts",
      "types": "./src/*/index.ts"
    }
  },
  "scripts": {
    "format": "bun run repo package format",
    "start": "vite",
    "compile": "bun run repo package compile",
    "build": "bun run repo package compile && vite build --configLoader runner",
    "lint": "bun run repo package lint",
    "lint:style": "bun run repo package lint-style",
    "preview": "vite preview",
    "verify": "bun run repo package verify"
  },
  "dependencies": {
    "@jearle/ui-hooks": "workspace:*"
  },
  "peerDependencies": {
    "@mantine/core": "^9",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@jearle/config-bun": "workspace:*",
    "@jearle/config-oxlint": "workspace:*",
    "@jearle/config-tsconfig": "workspace:*",
    "@jearle/config-vite": "workspace:*"
  }
}
